# Copy this file to `.env` (in the project root) and fill in real values.
# `.env` is gitignored — never commit secrets.

# --- Database ---
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- LLM credentials ---
# Direct OpenAI usage (recommended for local dev):
OPENAI_API_KEY="sk-your-openai-api-key-here"
OPENAI_MODEL="gpt-4o-mini"

# Optional: Vercel AI Gateway instead of api.openai.com
# Set USE_VERCEL_AI_GATEWAY=1 to route through the gateway.
USE_VERCEL_AI_GATEWAY=0
AI_GATEWAY_API_KEY=""

# Optional org/project scoping for direct OpenAI calls
# OPENAI_ORGANIZATION=""
# OPENAI_PROJECT=""

# --- Frontend ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# FRONTEND_ORIGIN="https://your-deployed-frontend.example.com"
